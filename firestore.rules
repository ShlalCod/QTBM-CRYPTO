rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ════════════════════════════════════════════════════════════════════
    // USER PROFILES — each user reads/writes their own profile
    // ════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data)
                      .affectedKeys().hasAny(['role', 'kycStatus', 'status']);
    }

    // ════════════════════════════════════════════════════════════════════
    // WALLETS — user can read own + update own (client-side transactions)
    // Balance validation happens in the client SDK's runTransaction().
    // Security: only the owner can write — no cross-user writes possible.
    // ════════════════════════════════════════════════════════════════════
    match /wallets/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // ════════════════════════════════════════════════════════════════════
    // TRADES — user creates own trade records
    // ════════════════════════════════════════════════════════════════════
    match /trades/{tradeId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false; // trades are immutable after creation
    }

    // ════════════════════════════════════════════════════════════════════
    // ORDERS — user creates own order records
    // ════════════════════════════════════════════════════════════════════
    match /orders/{orderId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ════════════════════════════════════════════════════════════════════
    // TRANSACTIONS (deposits/withdrawals/transfers) — user creates own
    // ════════════════════════════════════════════════════════════════════
    match /transactions/{txId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false; // transactions are immutable
    }

    // ════════════════════════════════════════════════════════════════════
    // KYC DOCUMENTS — user uploads metadata, admin/compliance can review
    // ════════════════════════════════════════════════════════════════════
    match /kyc/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || request.auth.token.admin == true
                      || request.auth.token.compliance == true);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
                    && (request.auth.uid == userId
                        || request.auth.token.admin == true
                        || request.auth.token.compliance == true);
    }

    // ════════════════════════════════════════════════════════════════════
    // NOTIFICATIONS — user can read own + mark as read
    // ════════════════════════════════════════════════════════════════════
    match /notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.diff(resource.data)
                      .affectedKeys().hasOnly(['isRead']);
      allow delete: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // EARN SUBSCRIPTIONS — user reads/creates own
    // ════════════════════════════════════════════════════════════════════
    match /earnSubscriptions/{subId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ════════════════════════════════════════════════════════════════════
    // P2P LISTINGS — public read; create/update own
    // ════════════════════════════════════════════════════════════════════
    match /p2pListings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.userId;
    }

    // ════════════════════════════════════════════════════════════════════
    // SUPPORT TICKETS — read/create own; admin can read all
    // ════════════════════════════════════════════════════════════════════
    match /supportTickets/{ticketId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.userId
                      || request.auth.token.admin == true
                      || request.auth.token.support == true);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.userId
                        || request.auth.token.admin == true
                        || request.auth.token.support == true);
    }

    // ════════════════════════════════════════════════════════════════════
    // PRICE ALERTS — full CRUD on own
    // ════════════════════════════════════════════════════════════════════
    match /priceAlerts/{alertId} {
      allow read, write: if request.auth != null
                         && (request.auth.uid == resource.data.userId
                             || request.auth.uid == request.resource.data.userId);
    }

    // ════════════════════════════════════════════════════════════════════
    // REFERRAL HISTORY — read own
    // ════════════════════════════════════════════════════════════════════
    match /referralHistory/{refId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // PUBLIC DATA — read-only for all
    // ════════════════════════════════════════════════════════════════════
    match /public/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // ADMIN COLLECTIONS — admin token required
    // ════════════════════════════════════════════════════════════════════
    match /admin/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.token.admin == true;
    }

    // ════════════════════════════════════════════════════════════════════
    // DEFAULT DENY — catch-all
    // ════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
