rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: admin check
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ════════════════════════════════════════════════════════════════════
    // USER PROFILES — owner reads/writes own; admin reads all
    // ════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
                    && (request.auth.uid == userId || isAdmin())
                    && !request.resource.data.diff(resource.data)
                      .affectedKeys().hasAny(['role', 'kycStatus', 'status']);
      // Only admin can change role/kycStatus/status via admin SDK
      // (client SDK update is blocked for those fields)
    }

    // ════════════════════════════════════════════════════════════════════
    // WALLETS — owner + admin can read; owner can update own
    // ════════════════════════════════════════════════════════════════════
    match /wallets/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // ════════════════════════════════════════════════════════════════════
    // TRADES — owner reads own; admin reads all; owner creates own
    // ════════════════════════════════════════════════════════════════════
    match /trades/{tradeId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // ORDERS — owner reads own; admin reads all
    // ════════════════════════════════════════════════════════════════════
    match /orders/{orderId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ════════════════════════════════════════════════════════════════════
    // TRANSACTIONS — owner reads own; admin reads all
    // ════════════════════════════════════════════════════════════════════
    match /transactions/{txId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // KYC DOCUMENTS — owner + admin/compliance
    // ════════════════════════════════════════════════════════════════════
    match /kyc/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════
    // NOTIFICATIONS — owner reads own; owner creates own; mark as read
    // ════════════════════════════════════════════════════════════════════
    match /notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.diff(resource.data)
                      .affectedKeys().hasOnly(['isRead']);
      allow delete: if false;
    }

    // ════════════════════════════════════════════════════════════════════
    // EARN SUBSCRIPTIONS — owner + admin
    // ════════════════════════════════════════════════════════════════════
    match /earnSubscriptions/{subId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ════════════════════════════════════════════════════════════════════
    // P2P LISTINGS — public read; create/update own
    // ════════════════════════════════════════════════════════════════════
    match /p2pListings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.userId;
    }

    // ════════════════════════════════════════════════════════════════════
    // SUPPORT TICKETS — owner + admin/support
    // ════════════════════════════════════════════════════════════════════
    match /supportTickets/{ticketId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════
    // PRICE ALERTS — full CRUD on own
    // ════════════════════════════════════════════════════════════════════
    match /priceAlerts/{alertId} {
      allow read, write: if request.auth != null
                         && (request.auth.uid == resource.data.userId
                             || request.auth.uid == request.resource.data.userId);
    }

    // ════════════════════════════════════════════════════════════════════
    // PUBLIC DATA — read-only for all; admin can write
    // ════════════════════════════════════════════════════════════════════
    match /public/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════
    // ADMIN COLLECTIONS (audit logs) — admin only
    // ════════════════════════════════════════════════════════════════════
    match /admin/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
