# =================================================================
# QTBM CRYPTO — Android release signing configuration
# =================================================================
# Copy this file to `keystore.properties` (in the android/ folder) and
# fill in the values for your production keystore.
#
# Generate a new release keystore with:
#   bun run keystore:generate
#
# Or with keytool directly:
#   keytool -genkeypair -v \
#     -keystore qtbm-release.keystore \
#     -alias qtbm \
#     -keyalg RSA -keysize 4096 \
#     -validity 10950 \
#     -storepass <your-store-password> \
#     -keypass <your-key-password>
# =================================================================

storeFile=qtbm-release.keystore
storePassword=CHANGE_ME_STORE_PASSWORD
keyAlias=qtbm
keyPassword=CHANGE_ME_KEY_PASSWORD
