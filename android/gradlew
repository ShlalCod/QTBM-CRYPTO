#!/usr/bin/env sh
# =================================================================
# QTBM CRYPTO — Gradle wrapper bootstrap script
# =================================================================
# This script ensures the Gradle wrapper is present before building.
# If `gradle-wrapper.jar` is missing (e.g. because jars are git-ignored),
# it downloads Gradle 8.7 and runs the wrapper task to bootstrap it.
# =================================================================
set -e

APP_HOME=$(cd "$(dirname "$0")" && pwd)
WRAPPER_JAR="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
WRAPPER_PROPS="$APP_HOME/gradle/wrapper/gradle-wrapper.properties"

if [ ! -f "$WRAPPER_JAR" ]; then
  echo "▶ gradle-wrapper.jar missing — bootstrapping with system Gradle…"

  if command -v gradle >/dev/null 2>&1; then
    (cd "$APP_HOME" && gradle wrapper --gradle-version 8.7 --distribution-type bin)
  else
    echo "✗ Neither gradle-wrapper.jar nor a system gradle is available." >&2
    echo "  Install Gradle 8.7+ (https://gradle.org/install/) and re-run." >&2
    exit 1
  fi
fi

# Hand off to the real gradle wrapper
exec java $JAVA_OPTS -classpath "$WRAPPER_JAR" org.gradle.wrapper.GradleWrapperMain "$@"
