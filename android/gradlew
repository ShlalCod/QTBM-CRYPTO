#!/usr/bin/env sh
# =================================================================
# QTBM CRYPTO — Gradle wrapper bootstrap script
# =================================================================
# If gradle-wrapper.jar is missing, download it from the official
# Gradle 8.7.0 release on GitHub. This avoids the version-mismatch
# problem where `gradle wrapper` (system gradle) overwrites our
# pinned gradle-wrapper.properties with the system version.
# =================================================================
set -e

APP_HOME=$(cd "$(dirname "$0")" && pwd)
WRAPPER_JAR="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
WRAPPER_PROPS="$APP_HOME/gradle/wrapper/gradle-wrapper.properties"

if [ ! -f "$WRAPPER_JAR" ]; then
  echo "▶ gradle-wrapper.jar missing — downloading Gradle 8.7.0 wrapper jar…"
  mkdir -p "$APP_HOME/gradle/wrapper"
  # The wrapper jar is identical across Gradle 8.x patch releases.
  # We pull it from the official gradle/gradle GitHub repo at tag v8.7.0.
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$WRAPPER_JAR" \
      https://raw.githubusercontent.com/gradle/gradle/v8.7.0/gradle/wrapper/gradle-wrapper.jar
  elif command -v wget >/dev/null 2>&1; then
    wget -q -O "$WRAPPER_JAR" \
      https://raw.githubusercontent.com/gradle/gradle/v8.7.0/gradle/wrapper/gradle-wrapper.jar
  else
    echo "✗ Need curl or wget to download the Gradle wrapper jar." >&2
    exit 1
  fi
  if [ ! -s "$WRAPPER_JAR" ]; then
    echo "✗ Failed to download gradle-wrapper.jar." >&2
    exit 1
  fi
  echo "✓ Downloaded gradle-wrapper.jar ($(wc -c < "$WRAPPER_JAR") bytes)"
fi

# Hand off to the real gradle wrapper
exec java $JAVA_OPTS -classpath "$WRAPPER_JAR" org.gradle.wrapper.GradleWrapperMain "$@"
